{
  "name": "remote-app",
  "version": "1.0.0",
  "description": "Custom Remote Desktop",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.yourname.remote",
    "productName": "Remote Desktop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "latest",
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.8.3",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
}
