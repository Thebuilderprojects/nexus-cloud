{
  "name": "remote-app",
  "version": "1.0.0",
  "description": "Nexus Custom Remote Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.yourname.nexusremote",
    "productName": "Nexus Remote",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.8.3"
},
"optionalDependencies": {
    "robotjs": "^0.6.0"
}
}